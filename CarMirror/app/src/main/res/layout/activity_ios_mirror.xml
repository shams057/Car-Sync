<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Mirror surface for video stream -->
    <SurfaceView
        android:id="@+id/surfaceMirror"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Loading / instruction state -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_primary"
        android:padding="48dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="64sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="iOS Mirror"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="@font/display"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:fontFamily="@font/mono"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.03"
            android:text="Follow steps below to mirror your iPhone/iPad" />

        <!-- Step instructions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="20dp"
            android:layout_marginTop="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETUP INSTRUCTIONS"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:letterSpacing="0.14"
                android:fontFamily="@font/mono"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvStep1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1  Connect iPhone to this unit via USB"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/mono"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvStep2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2  Trust this computer on your iPhone"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/mono"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvStep3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3  Tap START below — scrcpy will handle the rest"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/mono" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start Mirror"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Status chip -->
        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ waiting for device"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="@font/mono"
            android:layout_marginTop="14dp" />

    </LinearLayout>

    <!-- HUD shown while mirroring -->
    <LinearLayout
        android:id="@+id/layoutHud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="@color/hud_bg"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="● iOS Mirror"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:fontFamily="@font/mono" />

        <TextView
            android:id="@+id/btnStopMirror"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕ stop"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:fontFamily="@font/mono"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
